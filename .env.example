# ──────────────────────────────────────────────────────────────
# OFB Document Discovery System — Environment Configuration
# Copy this to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# API Security (comma-separated list of valid keys)
API_KEYS=change-me-key-1,change-me-key-2

# ── LLM Provider ─────────────────────────────────────────────
# Choose one: ollama, openai, anthropic
LLM_PROVIDER=ollama

# ── Ollama Configuration (recommended) ───────────────────────
OLLAMA_BASE_URL=http://192.168.0.207:8080
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_TIMEOUT=120

# ── Embedding ────────────────────────────────────────────────
EMBEDDING_DIMS=768

# ── OpenAI Configuration (alternative) ───────────────────────
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Anthropic Configuration (alternative) ────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ── MySQL — ofbdb ────────────────────────────────────────────
OFBDB_HOST=127.0.0.1
OFBDB_PORT=3306
OFBDB_USER=root
OFBDB_PASSWORD=
OFBDB_DATABASE=ofbdb

# ── MySQL — misofb ──────────────────────────────────────────
MISOFB_HOST=127.0.0.1
MISOFB_PORT=3306
MISOFB_USER=root
MISOFB_PASSWORD=
MISOFB_DATABASE=misofb

# ── FAISS Vector Store ───────────────────────────────────────
FAISS_PERSIST_DIR=./faiss_index
FAISS_COLLECTION_NAME=ofb_documents

# ── Vectorizer tuning ────────────────────────────────────────
EMBED_BATCH_SIZE=16
FETCH_CHUNK_SIZE=500
NUM_EMBED_WORKERS=2
SAVE_EVERY_N=2000

# ── RAG Configuration ────────────────────────────────────────
RAG_TOP_K=5
RAG_MAX_TOKENS=2048
RAG_TEMPERATURE=0.1
RAG_RERANK_ENABLED=true

# ── Sync ─────────────────────────────────────────────────────
SYNC_INTERVAL_SECONDS=120

# ── Server ───────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=*
DEBUG=false
